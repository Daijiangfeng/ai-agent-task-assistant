# ============================================
# AI Agent Task Assistant - Environment Config
# ============================================

# -- 智谱 LLM 配置（Anthropic 兼容端点） --
# API Key 申请地址：https://open.bigmodel.cn
ANTHROPIC_AUTH_TOKEN=your_zhipu_api_key_here
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ZHIPU_MODEL=glm-4-plus
ZHIPU_TEMPERATURE=0.7
ZHIPU_MAX_TOKENS=4096

# -- 智谱 OpenAI 兼容端点（Embedding 专用） --
ZHIPU_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_EMBEDDING_MODEL=embedding-3

# -- PostgreSQL --
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# -- Redis --
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# -- RabbitMQ --
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# -- Milvus --
MILVUS_HOST=localhost
MILVUS_PORT=19530

# -- Web Search (Tavily) --
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# -- Chroma 向量库 --
# 留空则使用默认目录 data/chroma
CHROMA_PERSIST_DIR=

# -- RAG 配置 --
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5

# -- SQLite 沙箱（SQL Query 工具） --
# 留空则使用默认路径 data/sandbox.db
SQLITE_SANDBOX_PATH=

# -- Memory 配置 --
ENABLE_LONG_TERM_MEMORY=false

# -- Agent 配置 --
MAX_REPLAN_ITERATIONS=3
MAX_EXECUTION_STEPS=10

# -- 应用配置 --
APP_NAME=AI Agent Task Assistant
DEBUG=false
